<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Sample_Maui.Controls"
             x:Class="Sample_Maui.Controls.MyPicker">
    
    <StackLayout>
        <Label Text="Hello Xamarin.Forms!" />
        <local:MyPicker x:Name="picker" Title="SelectNumber">
            <local:MyPicker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>100</x:String>
                    <x:String>200</x:String>
                    <x:String>300</x:String>
                    <x:String>400</x:String>
                    <x:String>500</x:String>
                    <x:String>600</x:String>
                    <x:String>700</x:String>
                </x:Array>
            </local:MyPicker.ItemsSource>
        </local:MyPicker>
    </StackLayout>
</ContentPage>